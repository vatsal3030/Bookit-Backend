# ==========================================
# BACKEND RENDER ENVIRONMENT VARIABLES
# ==========================================

# ─── DATABASE ─────────────────────────────
# Prisma connection URL. Required for Render deployment.
# We highly recommend using a Supabase PostgreSQL Connection String (Session/Transaction mode).
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database
# Format: postgresql://postgres:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="YOUR_SUPABASE_CONNECTION_STRING_HERE"

# ─── SERVER SETUP ─────────────────────────
# Server Port (Render will likely ignore this and use its own, but good for local)
PORT=5000

# ─── CORS URL (IMPORTANT FOR VERCEL) ──────
# Set this to your **Frontend Vercel URL** so the backend accepts requests.
# Local: http://localhost:5173
# Production (Vercel): https://your-frontend.vercel.app
FRONTEND_URL="https://your-frontend.vercel.app"

# ─── AUTHENTICATION ───────────────────────
# JWT Secret for Session Management.
# Required. Generate a random long string for production.
JWT_SECRET="YOUR_RANDOM_LONG_SECRET_KEY_HERE"

# Google OAuth Server Secrets
# Required for validating Google Sign-In requests.
# Get exactly the same ID as your Vercel frontend, and the secret key next to it in GCP.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID_HERE"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET_HERE"
