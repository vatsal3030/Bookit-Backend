# ─── DATABASE ───────────────────────────────
# Prisma database connection URL for PostgreSQL.
# Required. Supabase Postgres connection string recommended.
# Example: DATABASE_URL="postgresql://postgres:password@localhost:5432/appointments?schema=public"
DATABASE_URL=""

# ─── SERVER SETUP ───────────────────────────
# Node API Port (Target: 5000)
PORT=5000

# Client origin for CORS (e.g. http://localhost:5173 for local Vite proxy, or production URL)
CLIENT_URL="http://localhost:5173"

# ─── AUTHENTICATION ─────────────────────────
# JWT Secret for Session Management (Generated random long string advised)
# Required
JWT_SECRET="your_jwt_secret_key_here"

# Google OAuth Configuration
# Required for Google Sign-In button to work on frontend and backend
# Get this from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ─── FRONTEND (Vite / React) NOTE ───────────
# If deploying/testing Frontend Maps, you'll need the following in `frontend/.env`:
# VITE_GOOGLE_MAPS_API_KEY="your_google_maps_api_key"
# VITE_API_URL="http://localhost:5000/api"
